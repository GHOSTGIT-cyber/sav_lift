APP_NAME="SAV Lift Foils"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Base PostgreSQL managée par Coolify. En prod, ces valeurs viennent des
# variables d'env Coolify (l'hôte pointe le service Postgres interne).
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=sav
DB_USERNAME=sav
DB_PASSWORD=

# Compte administrateur du panneau /admin, (re)créé par AdminUserSeeder.
ADMIN_NAME="Admin SAV"
ADMIN_EMAIL=admin@liftfoils.fr
ADMIN_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# En local, `log` écrit l'accusé de réception dans storage/logs au lieu de
# l'envoyer. En production (Coolify), SMTP OVH :
#   MAIL_MAILER=smtp  MAIL_HOST=ssl0.ovh.net  MAIL_PORT=465  MAIL_ENCRYPTION=ssl
#   MAIL_USERNAME=sav@liftfoils.fr  MAIL_PASSWORD=…
# (valeurs à confirmer dans le panneau OVH : elles diffèrent en Email Pro/Exchange)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="sav@liftfoils.fr"
MAIL_FROM_NAME="SAV Lift Foils France"

# --- Relève IMAP de la boîte sav@ (Bloc 1) ---------------------------------
# webklex/laravel-imap parle le protocole nativement : aucune extension PHP
# `imap` n'est requise.
#
# L'adresse de la boîte sert de garde-fou anti-boucle : un mail qui en vient
# est ignoré. Chez OVH, c'est aussi l'identifiant IMAP, donc IMAP_USERNAME
# suffit. Si votre hébergeur sépare les deux (alias, Exchange), renseignez
# SAV_MAILBOX avec l'adresse réelle.
# SAV_MAILBOX=sav@liftfoils.fr
IMAP_HOST=ssl0.ovh.net
IMAP_PORT=993
IMAP_ENCRYPTION=ssl
IMAP_VALIDATE_CERT=true
IMAP_USERNAME=sav@liftfoils.fr
IMAP_PASSWORD=
IMAP_PROTOCOL=imap
IMAP_DEFAULT_ACCOUNT=default

# Dossier relevé, et fenêtre de relève en jours. On ne se fie pas au flag
# \Seen (des humains lisent la boîte) : la dédup se fait sur le Message-ID,
# donc on repasse volontairement sur cette fenêtre à chaque passage.
SAV_IMAP_FOLDER=INBOX
SAV_FETCH_DAYS=14

# Interrupteur général d'envoi. false = AUCUN mail ne part (accusé, demande
# d'infos, brouillon Lift) : l'envoi est simulé et journalisé. À passer à true
# seulement au feu vert, quand tout est prêt à écrire aux clients.
SAV_ENVOI_ACTIF=false

# Pièce jointe au-delà de laquelle on n'écrit rien sur le disque, et message
# au-delà duquel on ne parse même pas le corps (garde-fou mémoire : à garder
# sous le memory_limit de PHP).
SAV_MAX_ATTACHMENT_MB=40
SAV_MAX_MESSAGE_MB=60

# --- Extraction IA (Bloc 2) ------------------------------------------------
# Fournisseur compatible OpenAI (chat/completions). Par défaut OpenRouter, qui
# propose des modèles gratuits. Sans clé, l'extraction est désactivée : les
# dossiers sont créés mais non enrichis. Ne JAMAIS commiter la vraie clé.
SAV_IA_CLE=
# OPENROUTER_API_KEY / XAI_API_KEY sont aussi acceptés (replis de SAV_IA_CLE).
#
# OpenRouter (défaut). NE JAMAIS créditer le compte ni activer l'auto top-up :
# sans carte ni crédits, la facturation est impossible (un modèle payant renvoie
# une erreur 402, il ne débite pas). Utiliser UNIQUEMENT des modèles « :free ».
# Quota gratuit : 50 requêtes/jour, 20/min → largement suffisant ici.
SAV_IA_URL=https://openrouter.ai/api/v1/chat/completions
SAV_IA_MODELE=google/gemma-4-26b-a4b-it:free
#   Gemma est le seul modèle gratuit testé qui extrait TOUT correctement sur un
#   vrai mail SAV français (produit + modèle + MHS verbatim). À ne pas changer à
#   la légère : l'accusé de réception réclame au client ce que l'extraction rate.
#   Les « :free » vont et viennent : en cas de 404/429 persistant, relister via
#   https://openrouter.ai/api/v1/models (champ pricing à 0).
#
# REPLI si le gratuit d'OpenRouter se tarit — Groq (gratuit, généreux, sans carte).
# Basculer = ces deux lignes + la clé Groq. Aucun changement de code :
#   SAV_IA_URL=https://api.groq.com/openai/v1/chat/completions
#   SAV_IA_MODELE=llama-3.3-70b-versatile
#
# SAV_IA_JSON_MODE=true   # passer à false si le modèle refuse response_format

# --- Mode démonstration ----------------------------------------------------
# Une instance publique, SANS MOT DE PASSE, peuplée de dossiers fictifs, pour
# montrer l'outil sans donner d'accès à la production.
#
# ⚠️ NE JAMAIS METTRE true SUR L'APP DE PRODUCTION.
#
# Ce drapeau ne suffit d'ailleurs pas : App\Support\ModeDemo exige EN PLUS que
# l'instance soit incapable de toucher au monde réel — aucun IMAP_PASSWORD, et
# SAV_ENVOI_ACTIF=false. Si l'une des deux conditions manque, le mode démo se
# REFUSE et le panneau réclame un mot de passe, comme en prod. Une faute de
# frappe ici ne peut donc pas ouvrir les vrais dossiers à tout Internet.
SAV_DEMO=false
# SAV_DEMO_EMAIL=demo@liftfoils.fr   # le compte du visiteur, créé par DemoSeeder

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
